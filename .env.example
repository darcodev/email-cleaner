# Copy this file to ".env" and fill in your details, then run the tool.
# Your normal password will NOT work over IMAP - you need an app password.
# Gmail: https://myaccount.google.com/apppasswords  (needs 2-Step Verification)

EMAIL_CLEANER_EMAIL=you@gmail.com
EMAIL_CLEANER_PASSWORD=your-16-char-app-password

# Only needed for providers we can't auto-detect from your address
# (i.e. not gmail / outlook / yahoo / icloud):
# EMAIL_CLEANER_HOST=mail.example.com
# EMAIL_CLEANER_PORT=993

# Optional AI keep/delete pass (off by default; turn on per run with --ai).
# It only ever narrows the matches the normal filters already found. Leave the
# backend unset and nothing here does anything. See the README "AI-assisted
# filtering" section, and note that a hosted backend sends senders and subjects
# of the matching messages to that provider.
# EMAIL_CLEANER_AI_BACKEND=ollama            # ollama (local), openai, or anthropic
# EMAIL_CLEANER_AI_PROMPT=marketing and newsletters, but keep orders, flights and money
# EMAIL_CLEANER_AI_MODEL=llama3.1            # per-backend default if unset
# EMAIL_CLEANER_AI_API_KEY=                  # required for the hosted backends only
# EMAIL_CLEANER_AI_HOST=http://localhost:11434  # base URL; only for a custom endpoint
